# ============================================================
# AI Brand Content Strategist — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# REQUIRED: Google API key for Gemini models
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# REQUIRED: Tell ADK to use API key auth (not Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# OPTIONAL: Serper API key for real web search via MCP tools
# Get a free key at: https://serper.dev
# If not set, the MCP research tools will use realistic mock data as fallback
SERPER_API_KEY=

# OPTIONAL: LinkedIn access token for real publishing
# If not set, publishing will be simulated (clearly labeled)
# See: https://learn.microsoft.com/en-us/linkedin/shared/authentication/
LINKEDIN_ACCESS_TOKEN=
